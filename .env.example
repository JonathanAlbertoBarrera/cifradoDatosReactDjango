# =====================================================
# ARCHIVO .env DE EJEMPLO
# =====================================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# =====================================================
# SEGURIDAD - CIFRADO
# =====================================================
# Genera la clave AES ejecutando: python generar_clave_aes.py
# Copia la clave generada aquí:
AES_SECRET_KEY=

# =====================================================
# BASE DE DATOS MYSQL
# =====================================================
DB_NAME=ejemplo_cifrado
DB_USER=root
DB_PASSWORD=tu_password_mysql_aqui
DB_HOST=localhost
DB_PORT=3306

# =====================================================
# DJANGO
# =====================================================
DJANGO_SECRET_KEY=django-insecure-cambia-esto-en-produccion

# =====================================================
# FRONTEND (opcional)
# =====================================================
FRONTEND_URL=http://localhost:5173
